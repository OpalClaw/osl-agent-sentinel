# =============================================================================
# osl-agent-sentinel — Example Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# All values are documented in docs/CONFIGURATION.md.
# =============================================================================

# --- Service identity ---
SENTINEL_ENV=development                       # development | staging | production
SENTINEL_SERVICE_NAME=osl-agent-sentinel
SENTINEL_LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
SENTINEL_LOG_FORMAT=json                       # json | console

# --- Control plane bind ---
SENTINEL_HOST=0.0.0.0
SENTINEL_PORT=8080
SENTINEL_WORKERS=4

# --- Policy ---
SENTINEL_POLICY_SOURCE=file                    # file | http | s3 | git
SENTINEL_POLICY_PATH=./config/policies/default.yaml
SENTINEL_POLICY_HOT_RELOAD=true
SENTINEL_POLICY_SIGNING_PUBKEY=./config/keys/policy_signing.pub
SENTINEL_POLICY_CACHE_DIR=./.sentinel-cache    # used in fail-closed degradation

# --- Identity (DIDs) ---
SENTINEL_DID_METHOD=key                        # key | web | ion
SENTINEL_DID_RESOLVER_URL=https://uniresolver.io/1.0/identifiers/
SENTINEL_AGENT_REGISTRY=file:///etc/sentinel/registry.json

# --- Storage ---
SENTINEL_DB_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
SENTINEL_REDIS_URL=redis://localhost:6379/0

# --- Audit log ---
SENTINEL_AUDIT_SINK=postgres                   # postgres | kafka | s3 | file
SENTINEL_AUDIT_S3_BUCKET=
SENTINEL_AUDIT_KAFKA_BOOTSTRAP=
SENTINEL_AUDIT_WORM=false
SENTINEL_AUDIT_SIGNING_KEY=./config/keys/audit_signing.key

# --- Observability ---
SENTINEL_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTINEL_PROMETHEUS_ENABLED=true
SENTINEL_PROMETHEUS_PORT=9090
SENTINEL_SIEM_EXPORTER=disabled                # disabled | cef | leef | json
SENTINEL_SIEM_SYSLOG_HOST=
SENTINEL_SIEM_SYSLOG_PORT=514

# --- Multi-tenancy ---
SENTINEL_TENANCY_ENABLED=true
SENTINEL_DEFAULT_TENANT=default
SENTINEL_TENANT_QUOTA_REQUESTS_PER_MINUTE=600

# --- Circuit breaker ---
SENTINEL_CB_FAILURE_THRESHOLD=5
SENTINEL_CB_RESET_TIMEOUT_SECONDS=30
SENTINEL_CB_HALF_OPEN_PROBES=3

# --- Sandbox (Rust engine) ---
SENTINEL_SANDBOX_DEFAULT_RING=R2               # R0 | R1 | R2 | R3
SENTINEL_SANDBOX_MAX_CPU_MS=500
SENTINEL_SANDBOX_MAX_MEMORY_MB=256

# --- API auth ---
SENTINEL_API_AUTH_MODE=jwt                     # jwt | mtls | oidc
SENTINEL_JWT_ISSUER=https://auth.example.com
SENTINEL_JWT_AUDIENCE=sentinel
SENTINEL_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
SENTINEL_MTLS_CA_CERT=./config/keys/mtls_ca.crt

# --- DLP scanner ---
SENTINEL_DLP_ENABLED=true
SENTINEL_DLP_RULES_PATH=./config/dlp/default.yaml

# --- Prompt-injection detector ---
SENTINEL_PI_DETECTOR_ENABLED=true
SENTINEL_PI_DETECTOR_THRESHOLD=0.75

# --- Tenant-scoped feature flags ---
SENTINEL_FEATURES_CMVK=true
SENTINEL_FEATURES_IATP=true
SENTINEL_FEATURES_REDTEAM_HARNESS=false
